{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-inline' https://checkout.razorpay.com https://fonts.googleapis.com; frame-src https://api.razorpay.com;"
        }
      ]
    }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/auth/register",         "destination": "/api/auth/register.js" },
    { "source": "/api/auth/login",            "destination": "/api/auth/login.js" },
    { "source": "/api/auth/logout",           "destination": "/api/auth/session.js" },
    { "source": "/api/session",               "destination": "/api/auth/session.js" },
    { "source": "/api/auth/google",           "destination": "/api/auth/google/index.js" },
    { "source": "/api/auth/callback/google",  "destination": "/api/auth/callback/google.js" },
    { "source": "/api/cart",                  "destination": "/api/cart/index.js" },
    { "source": "/api/cart/:path*",           "destination": "/api/cart/index.js" },
    { "source": "/api/razorpay/create-order", "destination": "/api/payment/create-order.js" },
    { "source": "/api/razorpay/verify",       "destination": "/api/payment/verify.js" },
    { "source": "/api/webhook",               "destination": "/api/webhook.js" },
    { "source": "/api/orders/:path*",         "destination": "/api/orders/index.js" },
    { "source": "/api/orders",                "destination": "/api/orders/index.js" },
    { "source": "/api/user/profile",           "destination": "/api/user/profile.js" },
    { "source": "/api/order-action",             "destination": "/api/order-action.js" },
    { "source": "/api/orders/customize",          "destination": "/api/orders/index.js" }
  ]
}
